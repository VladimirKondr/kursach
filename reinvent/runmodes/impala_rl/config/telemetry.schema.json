{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IMPALA Telemetry Configuration",
  "description": "Configuration schema for OpenTelemetry integration in IMPALA RL",
  "type": "object",
  "properties": {
    "service": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Service name identifier"
        },
        "version": {
          "type": "string",
          "description": "Service version"
        },
        "environment": {
          "type": "string",
          "enum": ["dev", "staging", "prod"],
          "description": "Deployment environment"
        }
      },
      "required": ["name", "version", "environment"]
    },
    "traces": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable tracing"
        },
        "exporter": {
          "$ref": "#/definitions/exporter"
        },
        "sampling": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["always_on", "always_off", "parent_based", "trace_id_ratio"]
            },
            "ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "required": ["type", "ratio"]
        },
        "resource_attributes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["enabled", "exporter", "sampling"]
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "exporter": {
          "$ref": "#/definitions/exporter"
        },
        "interval_seconds": {
          "type": "integer",
          "minimum": 5,
          "description": "Metric export interval in seconds"
        },
        "views": {
          "type": "object",
          "properties": {
            "histogram_boundaries": {
              "type": "array",
              "items": {
                "type": "number"
              }
            }
          }
        }
      },
      "required": ["enabled", "exporter", "interval_seconds"]
    },
    "logs": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "level": {
          "type": "string",
          "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
        },
        "format": {
          "type": "string",
          "enum": ["json", "text"]
        },
        "exporter": {
          "$ref": "#/definitions/exporter"
        },
        "include_trace_context": {
          "type": "boolean"
        }
      },
      "required": ["enabled", "level", "format", "exporter"]
    }
  },
  "required": ["service", "traces", "metrics", "logs"],
  "definitions": {
    "exporter": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["otlp", "console", "noop"]
        },
        "endpoint": {
          "type": "string",
          "format": "uri"
        },
        "insecure": {
          "type": "boolean"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["type", "endpoint", "insecure"]
    }
  }
}
